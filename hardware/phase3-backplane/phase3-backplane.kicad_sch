  (global_label "VBUS" (shape passive) (at 60.96 172.72 0) (fields_autoplaced) (effects (font (size 1.27 1.27))) (uuid db7fd6cd-f39e-4fab-afda-dd67e3c160ee))
  (label "VBUS_IN" (at 76.2 172.72 0) (effects (font (size 1.27 1.27))) (uuid 4c59d813-f70b-4c17-bcf5-0382ef8d0210))
  (text "BACKPLANE (docs/09 s.2): near-passive. Bus entry: lugs -> 250uOhm bar shunt\n(placeholder fp; real bar at the PCB pass) -> INA228 high-side meter (0x40 on\nthe manager-local I2C; pull-ups live on the manager). E-stop: 3V3 THROUGH the\nNC panel switch -> 1K -> HW_EN; broken wire / unplugged manager = all SAFE.\nCAN: 120R at both physical ends; manager is a stub. Slot straps: grounded pin\n= bit set (fw board.h SLOT_ID_IN inverts) -> slot 0 = all open." (at 25.4 190.5 0) (effects (font (size 1.27 1.27))) (uuid 5f143942-2c94-485e-b90a-3f436524592e))
