  (global_label "FB" (shape output) (at 218.44 102.87 90) (fields_autoplaced) (effects (font (size 1.27 1.27))) (uuid c36bc6f8-4377-4dd0-94fa-0349540ec80f))
  (text "CONTROL CORE - dual error amps + diode-OR minimum selector into LM5145 FB node.\nWhichever amp demands the LOWER output wins -> automatic CV/CC crossover.\nAccuracy is owned by the 0.1% dividers + DAC + amp offset (see docs/06 s.4)." (at 33.02 40.64 0) (effects (font (size 1.27 1.27))) (uuid ff31a056-88c6-4fda-87ee-4f17c22571e2))
  (text "DAC80502DRXT (WSON-10): SPI2C->AGND = SPI mode; RSTSEL->AGND = zero-code POR\n(both verified vs datasheet). DAC runs on 3V3 = STM32 IO rail (IOVDD<=VDD rule).\nEAs: OPA2333 (RRIO; OPA2189 rejected - input CM stops 2.5V below V+)." (at 33.02 190.5 0) (effects (font (size 1.27 1.27))) (uuid 31f96e4c-2685-479f-a8c5-a10c2e8d60b0))
